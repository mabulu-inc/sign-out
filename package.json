{
  "name": "sign-out",
  "version": "1.0.1",
  "private": true,
  "description": "Lambda handler for sign-out. Soft-expires the session via @smplcty/auth revokeSession.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint src tests scripts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bundle": "pnpm run build && node scripts/bundle.js",
    "release": "git push origin main --follow-tags && gh release create v$(node -p \"require('./package.json').version\") --generate-notes"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@smplcty/auth": "^0.4.0",
    "@smplcty/logging": "^1.3.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@aws-sdk/client-ssm": "^3.840.0",
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.150",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
